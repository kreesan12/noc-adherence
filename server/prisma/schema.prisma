generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supervisor {
  id       Int    @id @default(autoincrement())
  fullName String
  email    String @unique
  hash     String
  role     String @default("supervisor")

  /// one-to-many: a supervisor **has many** agents
  agents Agent[] @relation("AgentSupervisor")

  /// existing back-relations
  auditLogs      AuditLog[]      @relation("SupervisorAuditEntries")
  attendanceLogs AttendanceLog[] @relation("SupervisorAttendance")

  overtimeEntries OvertimeEntry[]  @relation("SupervisorOvertimeEntries")
  signature       StoredSignature? @relation("SupervisorSignature")
}

model Agent {
  id          Int     @id @default(autoincrement())
  fullName    String
  email       String? @unique
  hash        String?
  phone       String?
  role        String?
  standbyFlag Boolean @default(false)

  /// HR metadata
  employeeNo String?   @map("employee_no")
  startDate  DateTime? @map("start_date")
  address    String?
  province   String?

  /// FK to Supervisor (nullable = can be un-assigned)
  supervisorId Int?        @map("supervisor_id")
  supervisor   Supervisor? @relation("AgentSupervisor", fields: [supervisorId], references: [id])

  /// existing back-relations
  engagements  Engagement[]
  shifts       Shift[]
  leave        Leave[]
  auditEntries AuditLog[]   @relation("AgentAuditEntries")

  overtimeEntries OvertimeEntry[]
  overtimeCreated OvertimeEntry[] @relation("OvertimeCreatedBy")

  @@map("Agent")
}

model Shift {
  id      Int    @id @default(autoincrement())
  agentId Int?
  agent   Agent? @relation(fields: [agentId], references: [id])

  shiftDate DateTime @db.Date
  startAt   DateTime
  endAt     DateTime

  breakStart DateTime?
  breakEnd   DateTime?

  generatedBy String? @default("solver")

  // leave auto-flag (Feature 3)
  leaveId Int? // ← NEW
  leave   Leave? @relation(fields: [leaveId], references: [id])

  attendance AttendanceLog?
}

model Leave {
  id      Int   @id @default(autoincrement())
  agentId Int
  agent   Agent @relation(fields: [agentId], references: [id])

  reason    String
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
  createdBy String

  shifts Shift[] // ← NEW
}

model Duty {
  id   Int    @id @default(autoincrement())
  name String @unique

  logs AttendanceLog[]
}

model AttendanceLog {
  id      Int   @id @default(autoincrement())
  shiftId Int   @unique
  shift   Shift @relation(fields: [shiftId], references: [id])

  status        Status    @default(pending)
  checkIn       DateTime?
  lunchStart    DateTime?
  lunchEnd      DateTime?
  overtimeStart DateTime?
  overtimeEnd   DateTime?

  dutyId Int?
  duty   Duty? @relation(fields: [dutyId], references: [id])

  supervisorId Int?
  supervisor   Supervisor? @relation("SupervisorAttendance", fields: [supervisorId], references: [id])
}

model VolumeForecast {
  id               Int      @id @default(autoincrement())
  role             String
  date             DateTime @db.Date
  hour             Int
  expectedCalls    Int
  expectedTickets  Int
  priority1        Int      @default(0)
  autoDfaLogged    Int      @default(0) @map("auto_dfa_logged")
  autoMntLogged    Int      @default(0) @map("auto_mnt_logged")
  autoOutageLinked Int      @default(0) @map("auto_outage_linked")
  autoMntSolved    Int      @default(0)
}

model VolumeActual {
  id               Int      @id @default(autoincrement())
  role             String
  date             DateTime @db.Date
  hour             Int
  calls            Int
  tickets          Int
  priority1        Int      @default(0)
  autoDfaLogged    Int      @default(0) @map("auto_dfa_logged")
  autoMntLogged    Int      @default(0) @map("auto_mnt_logged")
  autoOutageLinked Int      @default(0) @map("auto_outage_linked")
  autoMntSolved    Int      @default(0)

  @@unique([date, hour])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  actor     String
  payload   Json
  createdAt DateTime @default(now())

  // bidirectional links – optional
  agentId Int? // ← NEW
  agent   Agent? @relation("AgentAuditEntries", fields: [agentId], references: [id])

  supervisorId Int? // ← NEW
  supervisor   Supervisor? @relation("SupervisorAuditEntries", fields: [supervisorId], references: [id])
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())

  engagements Engagement[]
  vacancies   Vacancy[]
}

model Engagement {
  id      Int   @id @default(autoincrement())
  agentId Int
  agent   Agent @relation(fields: [agentId], references: [id])

  teamId Int
  team   Team @relation(fields: [teamId], references: [id])

  startDate DateTime  @db.Date // first day on team
  endDate   DateTime? @db.Date // null means still active
  note      String?

  createdAt DateTime @default(now())

  @@index([teamId, startDate, endDate])
}

enum VacancyStatus {
  OPEN
  AWAITING_APPROVAL
  APPROVED
  INTERVIEWING
  OFFER_SENT
  OFFER_ACCEPTED
  CLOSED
  PENDING
}

model Vacancy {
  id Int @id @default(autoincrement())

  // FKs
  teamId Int  @map("team_id")
  team   Team @relation(fields: [teamId], references: [id])

  // Core dates
  openFrom DateTime  @map("open_from")
  closedAt DateTime? @map("closed_at")

  // Status tracking
  status VacancyStatus @default(OPEN)

  // Candidate offer pipeline
  candidateName   String?   @map("candidate_name")
  candidateEmail  String?   @map("candidate_email")
  offerSentAt     DateTime? @map("offer_sent_at")
  offerAcceptedAt DateTime? @map("offer_accepted_at")
  startDate       DateTime? @map("start_date")

  // Optional free-text
  reason String? @db.VarChar(250)

  @@index([teamId])
  @@index([status])
  @@index([openFrom])
  @@map("Vacancy") // ← actual table name
}

enum Status {
  pending
  present
  late
  no_show
  off_sick
  emergency_leave
  awol
}

model Circuit {
  id             Int      @id @default(autoincrement())
  circuitId      String   @unique @map("circuit_id")
  nodeA          String   @map("node_a")
  nodeB          String   @map("node_b")
  nodeALat       Float?   @map("node_a_lat")
  nodeALon       Float?   @map("node_a_lon")
  nodeBLat       Float?   @map("node_b_lat")
  nodeBLon       Float?   @map("node_b_lon")
  techType       String   @map("tech_type")
  currentRxSiteA Float?   @map("current_rx_site_a")
  currentRxSiteB Float?   @map("current_rx_site_b")
  nldGroup       String?  @map("nld_group")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  levelHistory CircuitLevelHistory[]
  lightEvents  LightLevelEvent[]
  dailyLevels  DailyLightLevel[]
  blankRxIssues BlankDailyLightIssue[]
  stagedTicket  StagedZendeskTicket?
}

model Node {
  code     String  @id @map("code") // e.g. RIV, NEWG, CATO
  name     String  @map("name") // human name e.g. Riverhorse
  nldGroup String? @map("nld_group") // e.g. NLD1
  lat      Float   @map("lat")
  lon      Float   @map("lon")

  @@map("Node")
}

model CircuitLevelHistory {
  id          Int      @id @default(autoincrement())
  circuit     Circuit  @relation(fields: [circuitId], references: [id])
  circuitId   Int      @map("circuit_id")
  rxSiteA     Float?   @map("rx_site_a")
  rxSiteB     Float?   @map("rx_site_b")
  reason      String
  source      String
  changedById Int?     @map("changed_by_id")
  changedAt   DateTime @map("changed_at")
}

model LightLevelEvent {
  id            Int       @id @default(autoincrement())
  circuit       Circuit   @relation(fields: [circuitId], references: [id])
  circuitId     Int       @map("circuit_id")
  ticketId      Int?      @map("ticket_id")
  impactType    String?   @map("impact_type")
  eventDate     DateTime? @map("event_date")
  sideAPrev     Float?    @map("side_a_prev")
  sideACurr     Float?    @map("side_a_curr")
  sideBPrev     Float?    @map("side_b_prev")
  sideBCurr     Float?    @map("side_b_curr")
  sideADelta    Float?    @map("side_a_delta")
  sideBDelta    Float?    @map("side_b_delta")
  impactHours   Float?    @map("impact_hours")
  sourceEmailId String?   @map("source_email_id")
  createdAt     DateTime  @default(now()) @map("created_at")
}

model DailyLightLevel {
  id            Int      @id @default(autoincrement())
  circuit       Circuit  @relation(fields: [circuitId], references: [id])
  circuitId     Int      @map("circuit_id")
  side          String   @map("side") // 'A' or 'B'
  rx            Float?   @map("rx")
  mnemonic      String?  @map("mnemonic")
  routerName    String?  @map("router_name")
  parsedCode    String?  @map("parsed_code") // the 027... code we extract
  sourceEmailId String?  @map("source_email_id")
  sampleTime    DateTime @map("sample_time")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([circuitId, side, sampleTime], map: "uq_daily_circuit_side_time")
  @@index([parsedCode])
  @@map("daily_light_level")
}

model BlankDailyLightIssue {
  id            Int      @id @default(autoincrement())
  circuit       Circuit? @relation(fields: [circuitId], references: [id])
  circuitId     Int?     @map("circuit_id")
  side          String   @default("UNKNOWN")
  rawRx         String?  @map("raw_rx")
  mnemonic      String?
  routerName    String?  @map("router_name")
  parsedCode    String?  @map("parsed_code")
  sourceEmailId String?  @map("source_email_id")
  sampleTime    DateTime @map("sample_time")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([sampleTime, mnemonic, routerName], map: "uq_blank_daily_light_issue")
  @@index([sampleTime], map: "idx_blank_daily_light_issue_sample_time")
  @@index([parsedCode], map: "idx_blank_daily_light_issue_parsed_code")
  @@map("blank_daily_light_issue")
}

enum StockTemplateRowType {
  SECTION
  ITEM
}

model StockTemplateItem {
  id                     Int                  @id @default(autoincrement())
  rowOrder               Int                  @unique @map("row_order")
  rowType                StockTemplateRowType @map("row_type")
  sectionName            String?              @map("section_name")
  itemDescription        String?              @map("item_description")
  stockCode              String?              @map("stock_code")
  unitPriceZar           String?              @map("unit_price_zar")
  unitPriceUsd           String?              @map("unit_price_usd")
  division               String?
  requiredCpt            Int                  @default(0) @map("required_cpt")
  requiredJhb            Int                  @default(0) @map("required_jhb")
  requiredDbn            Int                  @default(0) @map("required_dbn")
  requiredPel            Int                  @default(0) @map("required_pel")
  requiredBfn            Int                  @default(0) @map("required_bfn")
  requiredGeo            Int                  @default(0) @map("required_geo")
  requiredPol            Int                  @default(0) @map("required_pol")
  requiredNel            Int                  @default(0) @map("required_nel")
  manualMatchItemNo      String?              @map("manual_match_item_no")
  manualMatchDescription String?              @map("manual_match_description")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  notWarehouseActions    StockNotWarehouseAction[]

  @@index([rowType], map: "idx_stock_template_item_row_type")
  @@index([division], map: "idx_stock_template_item_division")
  @@map("stock_template_item")
}

model StockNotWarehouseAction {
  id             Int               @id @default(autoincrement())
  templateItemId Int               @map("template_item_id")
  templateItem   StockTemplateItem @relation(fields: [templateItemId], references: [id], onDelete: Cascade)
  siteId         String            @map("site_id")
  status         String            @default("PENDING_REVIEW")
  notes          String?           @db.Text
  updatedBy      String?           @map("updated_by")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@unique([templateItemId, siteId], map: "uq_stock_not_warehouse_action_template_site")
  @@index([status], map: "idx_stock_not_warehouse_action_status")
  @@index([siteId], map: "idx_stock_not_warehouse_action_site")
  @@map("stock_not_warehouse_action")
}

model StockImportRun {
  id                 Int                     @id @default(autoincrement())
  reportDate         DateTime?               @map("report_date")
  sourceFilename     String?                 @map("source_filename")
  sourceEmailId      String?                 @map("source_email_id")
  sourceSubject      String?                 @map("source_subject")
  statusRowCount     Int                     @default(0) @map("status_row_count")
  matchedItemCount   Int                     @default(0) @map("matched_item_count")
  lowConfidenceCount Int                     @default(0) @map("low_confidence_count")
  unresolvedItemCount Int                    @default(0) @map("unresolved_item_count")
  unknownSiteCount   Int                     @default(0) @map("unknown_site_count")
  createdAt          DateTime                @default(now()) @map("created_at")
  statusRows         StockStatusCurrentRow[]
  historyRows        StockStatusHistoryRow[]

  @@index([createdAt], map: "idx_stock_import_run_created_at")
  @@map("stock_import_run")
}

model StockStatusCurrentRow {
  id                     Int            @id @default(autoincrement())
  importRunId            Int            @map("import_run_id")
  importRun              StockImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)
  itemNo                 String         @map("item_no")
  itemDescription        String         @map("item_description")
  itemShortName          String?        @map("item_short_name")
  itemClass              String?        @map("item_class")
  siteId                 String?        @map("site_id")
  itemGenericDescription String?        @map("item_generic_description")
  itemTrackingOption     String?        @map("item_tracking_option")
  qtyOnOrder             Int            @default(0) @map("qty_on_order")
  qtyAllocated           Int            @default(0) @map("qty_allocated")
  qtyOnHand              Int            @default(0) @map("qty_on_hand")
  qtyAvailable           Int            @default(0) @map("qty_available")
  valuationText          String?        @map("valuation_text")
  regionHint             String?        @map("region_hint")
  isWarehouseLike        Boolean        @default(false) @map("is_warehouse_like")
  createdAt              DateTime       @default(now()) @map("created_at")

  @@index([itemNo], map: "idx_stock_status_current_row_item_no")
  @@index([siteId], map: "idx_stock_status_current_row_site_id")
  @@index([regionHint], map: "idx_stock_status_current_row_region_hint")
  @@index([importRunId], map: "idx_stock_status_current_row_import_run_id")
  @@map("stock_status_current_row")
}

model StockStatusHistoryRow {
  id                     Int            @id @default(autoincrement())
  importRunId            Int            @map("import_run_id")
  importRun              StockImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)
  itemNo                 String         @map("item_no")
  itemDescription        String         @map("item_description")
  itemShortName          String?        @map("item_short_name")
  itemClass              String?        @map("item_class")
  siteId                 String?        @map("site_id")
  itemGenericDescription String?        @map("item_generic_description")
  itemTrackingOption     String?        @map("item_tracking_option")
  qtyOnOrder             Int            @default(0) @map("qty_on_order")
  qtyAllocated           Int            @default(0) @map("qty_allocated")
  qtyOnHand              Int            @default(0) @map("qty_on_hand")
  qtyAvailable           Int            @default(0) @map("qty_available")
  valuationText          String?        @map("valuation_text")
  regionHint             String?        @map("region_hint")
  isWarehouseLike        Boolean        @default(false) @map("is_warehouse_like")
  createdAt              DateTime       @default(now()) @map("created_at")

  @@index([itemNo], map: "idx_stock_status_history_row_item_no")
  @@index([siteId], map: "idx_stock_status_history_row_site_id")
  @@index([regionHint], map: "idx_stock_status_history_row_region_hint")
  @@index([importRunId], map: "idx_stock_status_history_row_import_run_id")
  @@map("stock_status_history_row")
}

model SlaProductTypeMap {
  id             Int      @id @default(autoincrement())
  rawProductType String   @unique @map("raw_product_type")
  productGroup   String   @map("product_group")
  sortOrder      Int      @default(99) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([productGroup], map: "idx_sla_product_type_map_group")
  @@index([isActive], map: "idx_sla_product_type_map_active")
  @@map("SlaProductTypeMap")
}

model SlaLinkMonthlyFact {
  id                         Int      @id @default(autoincrement())
  yearMonth                  String   @map("year_month")
  frogfootlinklabel          String   @map("frogfootlinklabel")
  isp                        String   @default("Unknown")
  region                     String   @default("Unknown")
  productType                String   @default("Unknown") @map("product_type")
  productGroup               String   @default("FTTB") @map("product_group")
  serviceType                String   @default("Unknown") @map("service_type")
  uptimePct                  Float?   @map("uptime_pct")
  activeHours                Float?   @map("active_hours")
  totalDowntimeHours         Float?   @map("total_downtime_hours")
  outageDowntimeHours        Float?   @map("outage_downtime_hours")
  ticketDowntimeHours        Float?   @map("ticket_downtime_hours")
  ticketCount                Int      @default(0) @map("ticket_count")
  serviceImpactingTicketCount Int     @default(0) @map("service_impacting_ticket_count")
  outageCount                Int      @default(0) @map("outage_count")
  outageImpactCount          Int      @default(0) @map("outage_impact_count")
  uniqueOutageLinkCount      Int      @default(0) @map("unique_outage_link_count")
  impacted                   Int      @default(0)
  breach                     Int      @default(0)
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@unique([yearMonth, frogfootlinklabel], map: "uq_sla_link_monthly_fact")
  @@index([yearMonth], map: "idx_sla_link_monthly_fact_month")
  @@index([isp, yearMonth], map: "idx_sla_link_monthly_fact_isp_month")
  @@index([productGroup, yearMonth], map: "idx_sla_link_monthly_fact_product_group_month")
  @@index([productType, yearMonth], map: "idx_sla_link_monthly_fact_product_type_month")
  @@index([serviceType, yearMonth], map: "idx_sla_link_monthly_fact_service_type_month")
  @@index([frogfootlinklabel, yearMonth], map: "idx_sla_link_monthly_fact_frg_month")
  @@map("sla_link_monthly_fact")
}

model SlaTicketMonthlyFact {
  id              Int      @id @default(autoincrement())
  yearMonth       String   @map("year_month")
  frg             String   @default("Unknown")
  isp             String   @default("Unknown")
  region          String   @default("Unknown")
  productType     String   @default("Unknown") @map("product_type")
  productGroup    String   @default("FTTB") @map("product_group")
  serviceType     String   @default("Unknown") @map("service_type")
  ticketId        String   @map("ticket_id")
  createdDate     DateTime? @map("created_date")
  impactStopTime  DateTime? @map("impact_stop_time")
  category        String   @default("Unknown")
  severity        String   @default("Unknown")
  partyAtFault    String   @default("Unknown") @map("party_at_fault")
  siteAccessTimes String?  @map("site_access_times")
  siteAccessSchedule String? @map("site_access_schedule")
  rawHours        Float    @default(0) @map("raw_hours")
  excludedHours   Float    @default(0) @map("excluded_hours")
  finalHours      Float    @default(0) @map("final_hours")
  serviceImpacting Boolean @default(false) @map("service_impacting")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([yearMonth, ticketId], map: "uq_sla_ticket_monthly_fact")
  @@index([yearMonth], map: "idx_sla_ticket_monthly_fact_month")
  @@index([frg, yearMonth], map: "idx_sla_ticket_monthly_fact_frg_month")
  @@index([productGroup, yearMonth], map: "idx_sla_ticket_monthly_fact_product_group_month")
  @@index([productType, yearMonth], map: "idx_sla_ticket_monthly_fact_product_type_month")
  @@index([serviceType, yearMonth], map: "idx_sla_ticket_monthly_fact_service_type_month")
  @@map("sla_ticket_monthly_fact")
}

model SlaOutageLinkMonthlyFact {
  id               Int      @id @default(autoincrement())
  yearMonth        String   @map("year_month")
  outageRef        String   @map("outage_ref")
  frogfootlinklabel String  @map("frogfootlinklabel")
  isp              String   @default("Unknown")
  linkRegion       String   @default("Unknown") @map("link_region")
  productType      String   @default("Unknown") @map("product_type")
  productGroup     String   @default("FTTB") @map("product_group")
  serviceType      String   @default("Unknown") @map("service_type")
  impactStart      DateTime? @map("impact_start")
  impactStop       DateTime? @map("impact_stop")
  impactType       String   @default("Unknown") @map("impact_type")
  causeClass       String   @default("Unknown") @map("cause_class")
  causeClassSub    String   @default("Unknown") @map("cause_class_sub")
  outageRegion     String   @default("Unknown") @map("outage_region")
  partyAtFault     String   @default("Unknown") @map("party_at_fault")
  summary          String?  @db.Text
  clientCount      Int      @default(0) @map("client_count")
  affectedLinksTotal Int    @default(0) @map("affected_links_total")
  incidentClass    String   @default("Minor Incident") @map("incident_class")
  durationHours    Float    @default(0) @map("duration_hours")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([yearMonth, outageRef, frogfootlinklabel], map: "uq_sla_outage_link_monthly_fact")
  @@index([yearMonth], map: "idx_sla_outage_link_monthly_fact_month")
  @@index([outageRef, yearMonth], map: "idx_sla_outage_link_monthly_fact_outage_month")
  @@index([frogfootlinklabel, yearMonth], map: "idx_sla_outage_link_monthly_fact_frg_month")
  @@index([productGroup, yearMonth], map: "idx_sla_outage_link_monthly_fact_product_group_month")
  @@index([productType, yearMonth], map: "idx_sla_outage_link_monthly_fact_product_type_month")
  @@index([serviceType, yearMonth], map: "idx_sla_outage_link_monthly_fact_service_type_month")
  @@map("sla_outage_link_monthly_fact")
}

model SlaMonthlyKpi {
  id                          Int      @id @default(autoincrement())
  yearMonth                   String   @map("year_month")
  productType                 String   @default("Unknown") @map("product_type")
  productGroup                String   @default("FTTB") @map("product_group")
  serviceType                 String   @default("Unknown") @map("service_type")
  totalLinks                  Int      @default(0) @map("total_links")
  impactedLinks               Int      @default(0) @map("impacted_links")
  breachLinks                 Int      @default(0) @map("breach_links")
  avgUptimePct                Float    @default(0) @map("avg_uptime_pct")
  worstUptimePct              Float    @default(0) @map("worst_uptime_pct")
  totalDowntimeHours          Float    @default(0) @map("total_downtime_hours")
  ticketCount                 Int      @default(0) @map("ticket_count")
  serviceImpactingTicketCount Int      @default(0) @map("service_impacting_ticket_count")
  outageCount                 Int      @default(0) @map("outage_count")
  outageImpactCount           Int      @default(0) @map("outage_impact_count")
  uniqueOutageLinkCount       Int      @default(0) @map("unique_outage_link_count")
  minorOutageCount            Int      @default(0) @map("minor_outage_count")
  majorOutageCount            Int      @default(0) @map("major_outage_count")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@unique([yearMonth, productType, productGroup, serviceType], map: "uq_sla_monthly_kpi")
  @@index([yearMonth], map: "idx_sla_monthly_kpi_month")
  @@index([productGroup, yearMonth], map: "idx_sla_monthly_kpi_product_group_month")
  @@index([productType, yearMonth], map: "idx_sla_monthly_kpi_product_type_month")
  @@index([serviceType, yearMonth], map: "idx_sla_monthly_kpi_service_type_month")
  @@map("sla_monthly_kpi")
}

model SlaIspMonthlySummary {
  id                 Int      @id @default(autoincrement())
  yearMonth          String   @map("year_month")
  isp                String   @default("Unknown")
  productType        String   @default("Unknown") @map("product_type")
  productGroup       String   @default("FTTB") @map("product_group")
  serviceType        String   @default("Unknown") @map("service_type")
  linkCount          Int      @default(0) @map("link_count")
  impactedLinks      Int      @default(0) @map("impacted_links")
  breachLinks        Int      @default(0) @map("breach_links")
  avgUptimePct       Float    @default(0) @map("avg_uptime_pct")
  worstUptimePct     Float    @default(0) @map("worst_uptime_pct")
  totalDowntimeHours Float    @default(0) @map("total_downtime_hours")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([yearMonth, isp, productType, productGroup, serviceType], map: "uq_sla_isp_monthly_summary")
  @@index([yearMonth], map: "idx_sla_isp_monthly_summary_month")
  @@index([isp, yearMonth], map: "idx_sla_isp_monthly_summary_isp_month")
  @@index([productGroup, yearMonth], map: "idx_sla_isp_monthly_summary_product_group_month")
  @@index([productType, yearMonth], map: "idx_sla_isp_monthly_summary_product_type_month")
  @@index([serviceType, yearMonth], map: "idx_sla_isp_monthly_summary_service_type_month")
  @@map("sla_isp_monthly_summary")
}

model StagedZendeskTicket {
  id                Int                          @id @default(autoincrement())
  reference         String                       @unique
  circuit           Circuit                      @relation(fields: [circuitId], references: [id])
  circuitId         Int                          @unique @map("circuit_id")
  subject           String
  latestCommentBody String?                      @map("latest_comment_body")
  priority          String
  status            String                       @default("OPEN")
  groupName         String                       @default("NOC Tier3") @map("group_name")
  ticketType        String                       @default("task") @map("ticket_type")
  tags              String[]                     @default([])
  breachSide        String?                      @map("breach_side")
  breachLevel       Int                          @default(1) @map("breach_level")
  initialLightLevel Float?                       @map("initial_light_level")
  latestLightLevel  Float?                       @map("latest_light_level")
  deltaLightLevel   Float?                       @map("delta_light_level")
  dateCreated       DateTime                     @default(now()) @map("date_created")
  openedAt          DateTime?                    @map("opened_at")
  escalatedAt       DateTime?                    @map("escalated_at")
  lastEvaluatedAt   DateTime                     @default(now()) @map("last_evaluated_at")
  updatedAt         DateTime                     @updatedAt @map("updated_at")
  comments          StagedZendeskTicketComment[]

  @@index([priority], map: "idx_staged_zendesk_ticket_priority")
  @@index([status], map: "idx_staged_zendesk_ticket_status")
  @@map("staged_zendesk_ticket")
}

model StagedZendeskTicketComment {
  id        Int                 @id @default(autoincrement())
  ticket    StagedZendeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  Int                 @map("ticket_id")
  body      String
  isPublic  Boolean             @default(true) @map("is_public")
  eventKind String?             @map("event_kind")
  createdAt DateTime            @default(now()) @map("created_at")

  @@index([ticketId, createdAt], map: "idx_staged_zendesk_ticket_comment_ticket_created")
  @@map("staged_zendesk_ticket_comment")
}

// NEW ENUM
enum ManagerRole {
  manager
  engineering
}

model Manager {
  id        Int         @id @default(autoincrement())
  fullName  String      @map("full_name") // ← map to full_name
  email     String      @unique
  password  String // column is already “password”
  role      ManagerRole @default(manager)
  createdAt DateTime    @default(now()) @map("created_at")
  lastLogin DateTime?   @map("last_login")

  overtimeEntries OvertimeEntry[]  @relation("ManagerOvertimeEntries")
  signature       StoredSignature? @relation("ManagerSignature")

  @@map("Manager") // table name stays quoted-capitalised
}

model NldService {
  id          Int     @id @default(autoincrement())
  customer    String
  frg         String
  serviceType String  @map("service_type")
  capacity    String
  nldRoute    String  @map("nld_route")
  deployment  String
  protection  Boolean
  priPath     String? @map("pri_path")
  secPath     String? @map("sec_path")
  stag        String?
  ctag        String?

  sideAName    String  @map("side_a_name")
  sideAIC      String? @map("side_a_ic")
  sideASO      String? @map("side_a_so")
  sideAHandoff String? @map("side_a_handoff")

  sideBName    String  @map("side_b_name")
  sideBIC      String? @map("side_b_ic")
  sideBSO      String? @map("side_b_so")
  sideBHandoff String? @map("side_b_handoff")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("NldService")
}

enum OvertimeSource {
  FIXED
  MANUAL
}

enum OvertimeStatus {
  DRAFT
  SUBMITTED
  SUPERVISOR_APPROVED
  MANAGER_APPROVED
  REJECTED
}

model OvertimePeriod {
  id        Int      @id @default(autoincrement())
  key       String   @unique // eg 2026_01_15__2026_02_14
  label     String // eg Jan to Feb 2026
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  createdAt DateTime @default(now())

  entries OvertimeEntry[]

  @@map("OvertimePeriod")
}

model PublicHoliday {
  id       Int      @id @default(autoincrement())
  date     DateTime @unique @db.Date
  name     String
  isActive Boolean  @default(true)

  @@map("PublicHoliday")
}

model OvertimeEntry {
  id Int @id @default(autoincrement())

  periodId Int            @map("period_id")
  period   OvertimePeriod @relation(fields: [periodId], references: [id])

  agentId Int   @map("agent_id")
  agent   Agent @relation(fields: [agentId], references: [id])

  source OvertimeSource
  status OvertimeStatus @default(DRAFT)

  workDate DateTime @map("work_date") @db.Date
  startAt  DateTime @map("start_at")
  endAt    DateTime @map("end_at")

  totalHours Decimal @map("total_hours") @db.Decimal(6, 2)
  rate       Decimal @map("rate") @db.Decimal(4, 2)

  reason String? @db.Text
  notes  String? @db.Text

  createdByAgentId Int?   @map("created_by_agent_id")
  createdByAgent   Agent? @relation("OvertimeCreatedBy", fields: [createdByAgentId], references: [id])

  supervisorId Int?        @map("supervisor_id")
  supervisor   Supervisor? @relation("SupervisorOvertimeEntries", fields: [supervisorId], references: [id])

  managerId Int?     @map("manager_id")
  manager   Manager? @relation("ManagerOvertimeEntries", fields: [managerId], references: [id])

  supervisorApprovedAt DateTime? @map("supervisor_approved_at")
  managerApprovedAt    DateTime? @map("manager_approved_at")

  editedRequiresManager Boolean @default(false) @map("edited_requires_manager")

  versions OvertimeEntryVersion[]

  @@index([periodId, agentId])
  @@index([workDate])
  @@map("OvertimeEntry")
}

model OvertimeEntryVersion {
  id      Int           @id @default(autoincrement())
  entryId Int           @map("entry_id")
  entry   OvertimeEntry @relation(fields: [entryId], references: [id])

  editedAt DateTime @default(now()) @map("edited_at")
  editedBy String   @map("edited_by") // store email or id string
  reason   String?  @db.Text

  before Json
  after  Json

  @@index([entryId])
  @@map("OvertimeEntryVersion")
}

enum SignatureRole {
  supervisor
  manager
}

model StoredSignature {
  id   Int           @id @default(autoincrement())
  role SignatureRole

  supervisorId Int?        @unique @map("supervisor_id")
  supervisor   Supervisor? @relation("SupervisorSignature", fields: [supervisorId], references: [id])

  managerId Int?     @unique @map("manager_id")
  manager   Manager? @relation("ManagerSignature", fields: [managerId], references: [id])

  imageDataUrl String   @map("image_data_url") @db.Text
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("StoredSignature")
}

enum AppointmentEventType {
  CREATED
  ASSIGNED
  MOVED
  STATUS_CHANGED
  TECH_MESSAGE
  ASSISTANCE_REQUESTED
  JOB_CARD_SUBMITTED
  ASSET_UPLOADED
}

enum ActorType {
  ROC
  TECH
  SYSTEM
}

enum AssetType {
  PHOTO
  SIGNATURE
}

enum JobOutcome {
  SUCCESSFUL
  UNSUCCESSFUL
}

model Technician {
  id                  String   @id
  name                String
  phone               String?  @unique
  region              String?
  area                String?

  vehicleRegistration String?  @map("vehicle_registration")
  vehicleType         String?  @map("vehicle_type")
  homeAddress         String?  @map("home_address")
  homeLat             Float?   @map("home_lat")
  homeLng             Float?   @map("home_lng")
  isActive            Boolean  @default(true) @map("is_active")

  appointments        Appointment[]

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("technicians")
}


model Ticket {
  id            String   @id
  externalRef   String?  @unique @map("external_ref")
  customerName  String   @map("customer_name")
  customerPhone String?  @map("customer_phone")
  address       String?
  lat           Float?
  lng           Float?
  notes         String?

  appointments  Appointment[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("tickets")
}


model Appointment {
  id              String            @id
  ticketId         String            @map("ticket_id")
  technicianId     String?           @map("technician_id")

  appointmentDate  DateTime          @map("appointment_date")
  slotNumber       Int?              @map("slot_number")
  windowStartTime  String?           @map("window_start_time")
  windowEndTime    String?           @map("window_end_time")

  status           AppointmentStatus @default(SCHEDULED)

  createdByUserId  String?           @map("created_by_user_id")
  updatedByUserId  String?           @map("updated_by_user_id")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  ticket           Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  technician       Technician?  @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  events           AppointmentEvent[]
  assets           AppointmentAsset[]
  jobCard          JobCard?

  @@index([appointmentDate])
  @@index([technicianId, appointmentDate])
  @@map("appointments")
}


model AppointmentEvent {
  id             String               @id
  appointmentId  String               @map("appointment_id")
  eventType      AppointmentEventType @map("event_type")
  actorType      ActorType            @map("actor_type")
  actorId        String?              @map("actor_id")
  eventTime      DateTime             @default(now()) @map("event_time")

  lat            Float?
  lng            Float?
  payload        Json?

  clientEventId  String?              @unique @map("client_event_id")

  createdAt      DateTime             @default(now()) @map("created_at")

  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, eventTime])
  @@map("appointment_events")
}


model AppointmentAsset {
  id             String    @id
  appointmentId  String    @map("appointment_id")
  assetType      AssetType @map("asset_type")
  fileUrl        String    @map("file_url")

  createdAt      DateTime  @default(now()) @map("created_at")

  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_assets")
}


model JobCard {
  id             String     @id
  appointmentId  String     @unique @map("appointment_id")

  outcome        JobOutcome
  reasonCode     String?    @map("reason_code")
  notes          String?
  civilsRequired Boolean    @default(false) @map("civils_required")

  signedByName   String?    @map("signed_by_name")
  signedAt       DateTime?  @map("signed_at")
  customerRating Int?       @map("customer_rating")

  createdAt      DateTime   @default(now()) @map("created_at")

  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("job_cards")
}

enum AppointmentStatus {
  UNASSIGNED
  SCHEDULED
  EN_ROUTE
  NEAR_SITE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  UNSUCCESSFUL
  CANCELLED

  @@map("AppointmentStatus")
}
